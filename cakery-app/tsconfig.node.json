{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noEmit": true,
    "composite": true,
    "outDir": "./.cache/tsbuildinfo",
    "tsBuildInfoFile": "./.cache/tsbuildinfo/tsconfig.node.tsbuildinfo"
  },
  "include": ["vite.config.ts", "postcss.config.js", "tailwind.config.ts"]
}
