# Copy this to `.env.local` (gitignored) and fill real values for local dev.
# All Vite env vars exposed to the browser MUST start with VITE_.

# Required: Formspree endpoint for the cake order form (https://formspree.io/forms)
# Format: https://formspree.io/f/<form_id>
VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/REPLACE_ME

# Optional: shop public phone (kept here so it can be branded per environment)
VITE_PHONE_DISPLAY=088 884 9908
VITE_PHONE_E164=+359888849908
