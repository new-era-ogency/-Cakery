# Copy this to `.env.local` (gitignored) for local development.
#
# IMPORTANT
# ─────────
# Variables prefixed with VITE_ are inlined into the client bundle and visible
# in DevTools. Anything else (e.g. FORMSPREE_URL) is SERVER-ONLY and is read
# by /api/order.ts at runtime via process.env.
#
# Vercel: add the same keys via Project Settings → Environment Variables.
# Netlify: same idea via Site settings → Build & deploy → Environment.

# ─── Server-only secrets ────────────────────────────────────────────────────
# Real Formspree endpoint (https://formspree.io/forms → copy the URL).
# This MUST NOT have a VITE_ prefix.
FORMSPREE_URL=https://formspree.io/f/REPLACE_WITH_FORM_ID

# ─── Client-side branding (safe to ship) ────────────────────────────────────
VITE_PHONE_DISPLAY=088 884 9908
VITE_PHONE_E164=+359888849908
